{
  "expo": {
    "name": "BioRegisto-Mobile",
    "slug": "BioRegisto-Mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/iconBio.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d723b"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/iconBio.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "bio.registo",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDJHvS4UwfLSEKN21C2hIqiqOwPKzf0NnE"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Permite ao BioRegisto aceder à tua localização para mostrar as observações no mapa."
        }
      ],
      "expo-font",
      "expo-secure-store"
    ],
    "scheme": "bioregisto",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "78071591-3e40-41d3-a7bf-0e8fac42c597"
      }
    }
  }
}
